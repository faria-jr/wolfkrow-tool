{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "incremental": false,
    "allowJs": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "e2e/**/*.ts", "playwright.config.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "storybook-static",
    "playwright-report",
    "test-results"
  ]
}

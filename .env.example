# Wolfkrow Tool — environment example
# Copy to .env and adjust. Secrets (provider keys, Telegram token, STT/TTS keys)
# are read from the Vault (OS keychain via keytar) at runtime, NOT from env.

# ── Web (apps/web, port 3000) ────────────────────────────────────────────────
# Worker URL used by the BFF Route Handlers (server-side).
WORKER_URL=http://localhost:4000
# Exposed to the browser only when needed.
NEXT_PUBLIC_WORKER_URL=http://localhost:4000

# ── Worker (apps/worker, port 4000) ──────────────────────────────────────────
PORT=4000
HOST=127.0.0.1
# Internal secret (>= 32 chars). REQUIRED in production (worker throws if unset).
WORKER_SECRET=dev-worker-secret-must-be-32-chars-long!!
# JWKS endpoint exposed by the web app to validate JWTs.
JWKS_URL=http://localhost:3000/.well-known/jwks.json
# Scheduler poll interval (ms).
WORKER_POLL_INTERVAL_MS=60000
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Shared ───────────────────────────────────────────────────────────────────
# SQLite path. Default resolves to $HOME/.wolfkrow/data/wolfkrow.db (cwd-
# independent — web/worker/migrate share the same file). Override with an
# absolute path only if you need a custom location.
# WOLFKROW_DB_PATH=/absolute/path/to/wolfkrow.db

# Embeddings for Knowledge/RAG (Voyage). Optional if you don't use semantic search.
# VOYAGE_API_KEY=

# ── Runtime (optional) ───────────────────────────────────────────────────────
NODE_ENV=development

{
  "name": "@wolfkrow/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./schemas": "./dist/schemas/index.js",
    "./events": "./dist/events/index.js",
    "./errors": "./dist/errors/index.js"
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "schemas": [
        "./dist/schemas/index.d.ts"
      ],
      "events": [
        "./dist/events/index.d.ts"
      ],
      "errors": [
        "./dist/errors/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^2.1.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

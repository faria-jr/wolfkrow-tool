{
  "name": "@wolfkrow/infra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./db/schema": {
      "types": "./dist/db/schema/index.d.ts",
      "default": "./dist/db/schema/index.js"
    },
    "./db/client": {
      "types": "./dist/db/client.d.ts",
      "default": "./dist/db/client.js"
    },
    "./repos": {
      "types": "./dist/repos/index.d.ts",
      "default": "./dist/repos/index.js"
    },
    "./ai-providers": {
      "types": "./dist/ai-providers/index.d.ts",
      "default": "./dist/ai-providers/index.js"
    },
    "./auth/jwt": {
      "types": "./dist/auth/jwt.d.ts",
      "default": "./dist/auth/jwt.js"
    },
    "./secrets/keytar-adapter": {
      "types": "./dist/secrets/keytar-adapter.d.ts",
      "default": "./dist/secrets/keytar-adapter.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.41.0",
    "@wolfkrow/domain": "workspace:*",
    "@wolfkrow/shared-types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.36.0",
    "jose": "^5.9.0",
    "keytar": "^7.9.0",
    "openai": "^6.44.0",
    "otplib": "^12.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.7.0",
    "@vitest/coverage-v8": "^2.1.4",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

{
  "name": "@wolfkrow/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json --incremental false",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.0.0",
    "@wolfkrow/domain": "workspace:*",
    "@wolfkrow/infra": "workspace:*",
    "@wolfkrow/use-cases": "workspace:*",
    "cron-parser": "^4.9.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "jose": "^5.9.0",
    "keytar": "^7.9.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@vitest/coverage-v8": "^2.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.4"
  }
}
